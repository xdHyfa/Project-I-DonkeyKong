o Sans\", \"Helvetica Neue\", Helvetica, Arial, sans-serif","font-size":"14px"}},{"selectors":["#iw3iu"],"style":{"color":"rgb(114, 114, 114)","font-family":"\"Noto Sans\", \"Helvetica Neue\", Helvetica, Arial, sans-serif","font-size":"14px"}},{"selectors":["#igf5o"],"style":{"color":"rgb(114, 114, 114)","font-family":"\"Noto Sans\", \"Helvetica Neue\", Helvetica, Arial, sans-serif","font-size":"14px"}},{"selectors":["#ifgs5"],"style":{"color":"rgb(34, 34, 34)","font-weight":"700","font-family":"\"Noto Sans\", \"Helvetica Neue\", Helvetica, Arial, sans-serif","font-size":"14px"}},{"selectors":["#ite6w"],"style":{"color":"rgb(34, 34, 34)","font-weight":"700","font-family":"\"Noto Sans\", \"Helvetica Neue\", Helvetica, Arial, sans-serif","font-size":"14px"}},{"selectors":["#ial3s"],"style":{"color":"rgb(34, 34, 34)","font-weight":"700"}},{"selectors":["#i2n5z"],"style":{"color":"rgb(114, 114, 114)","font-family":"\"Noto Sans\", \"Helvetica Neue\", Helvetica, Arial, sans-serif","font-size":"14px"}},{"selectors":["#i5k5z"],"style":{"color":"rgb(114, 114, 114)","font-family":"\"Noto Sans\", \"Helvetica Neue\", Helvetica, Arial, sans-serif","font-size":"14px"}},{"selectors":["#i93r8"],"style":{"color":"rgb(114, 114, 114)","font-family":"\"Noto Sans\", \"Helvetica Neue\", Helvetica, Arial, sans-serif","font-size":"14px"}},{"selectors":["#iys6z"],"style":{"color":"rgb(34, 34, 34)","font-weight":"700","font-family":"\"Noto Sans\", \"Helvetica Neue\", Helvetica, Arial, sans-serif","font-size":"14px"}},{"selectors":["gjs-grid-column"],"style":{"flex":"1 1 0%","padding":"5px 0"},"group":"cmp:gridColumn"},{"selectors":["gjs-grid-row"],"style":{"display":"flex","justify-content":"flex-start","align-items":"stretch","flex-direction":"row","min-height":"auto","padding":"10px 0"},"group":"cmp:gridRow"},{"selectors":["gjs-grid-row"],"style":{"flex-direction":"column"},"mediaText":"(max-width: 992px)","atRuleType":"media","group":"cmp:gridRow"},{"selectors":["#iptn9i"],"style":{"flex-basis":"30%","flex-grow":0}},{"selectors":["#iirhip"],"style":{"padding":"10px","font-size":"32px","font-family":"Verdana, Geneva, sans-serif"}},{"selectors":["#ihumcj"],"style":{"text-align":"center"}}],"pages":[{"name":"Web","frames":[{"component":{"type":"wrapper","attributes":{"id":"i8d1"},"components":[{"type":"gridRow","classes":["gjs-grid-row"],"attributes":{"id":"iqicze"},"components":[{"type":"gridColumn","classes":["gjs-grid-column"],"attributes":{"id":"ihumcj"},"components":[{"type":"image","resizable":{"ratioDefault":1},"attributes":{"src":"https://placehold.co/300/777/white.png?text=IMAGE","id":"ioqvgn"}}],"center-content":""}]},{"classes":["card"],"attributes":{"id":"i686"},"components":[{"type":"heading","classes":["title"],"attributes":{"id":"ir9u"},"components":[{"type":"textnode","content":"Project-I-DonkeyKong"}]},{"tagName":"p","type":"text","classes":["subtitle"],"attributes":{"id":"izkno"},"components":[{"type":"textnode","content":"SlopSquad 1st Year Project"}]},{"type":"gridRow","classes":["gjs-grid-row"],"attributes":{"id":"idp0nx"},"components":[{"type":"gridColumn","classes":["gjs-grid-column"],"attributes":{"id":"iptn9i"},"components":[{"type":"image","resizable":{"ratioDefault":1},"attributes":{"src":"https://placehold.co/300/777/white.png?text=IMAGE","id":"ivx6lt"}},{"type":"image","resizable":{"ratioDefault":1},"attributes":{"src":"https://placehold.co/300/777/white.png?text=IMAGE","id":"ip7ab8"}}],"center-content":""},{"type":"gridColumn","classes":["gjs-grid-column"],"attributes":{"id":"iymf2y"},"components":[{"type":"text","attributes":{"id":"iirhip"},"components":[{"type":"textnode","content":"Donkey Kong (1981)"},{"tagName":"br","void":true},{"type":"textnode","content":"CITM 2026, Bachelor's degree in Video Game Design and Development"},{"tagName":"br","void":true},{"tagName":"br","void":true},{"type":"textnode","content":"We are SlopSquad, an independent studio formed by students from CITM, at Barcelona. This page is dedicated to our 1st year's final project, a recreation of the 1981 arcade hit Donkey Kong!"},{"tagName":"br","void":true},{"tagName":"br","void":true},{"tagName":"br","void":true},{"tagName":"br","void":true},{"type":"textnode","content":"Released by Nintendo back in 1981, Donkey Kong wasn't just another arcade hit, it was the game that introduced us to the world's most famous plumber. Back then, you played as a character mostly known as \"Jumpman\". The vibe was pure old-school tension: you had to sprint across trusses, dodge falling barrels, and scramble up ladders in the middle of a New York City construction site. Your goal? To rescue Pauline, often just called \"The Lady\" in the original flyers, from the clutches of a giant, stubborn gorilla who wasn't about to give her up without a fight."},{"tagName":"br","void":true},{"tagName":"br","void":true},{"tagName":"br","void":true},{"tagName":"br","void":true},{"type":"textnode","content":"(Short Description of the main contributions of each member)"},{"tagName":"br","void":true},{"tagName":"br","void":true},{"tagName":"br","void":true},{"tagName":"br","void":true},{"tagName":"br","void":true},{"tagName":"br","void":true},{"tagName":"br","void":true},{"type":"textnode","content":"(Embedded gameplay video uploaded on YouTube of 1 or 2 minutes)"},{"tagName":"br","void":true},{"tagName":"br","void":true},{"tagName":"br","void":true},{"type":"textnode","content":"(Link to directly download the latest release)"}]}],"center-content":""}]}]}],"head":{"type":"head"},"docEl":{"tagName":"html"}},"id":"pMyIu6IszxFecwgv"}],"id":"Mqw3gQdktWBoaYkU"}],"symbols":[],"custom":{"projectType":"web","id":""}}